#!/usr/bin/env sh

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PREFIX_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
INSTALLED_TEMPLATE_ROOT=$PREFIX_ROOT/share/devcontainer-base/templates
REPO_TEMPLATE_ROOT=$PREFIX_ROOT
PROGRAM_NAME=${0##*/}

if [ -d "$INSTALLED_TEMPLATE_ROOT" ]; then
  TEMPLATE_ROOT=$INSTALLED_TEMPLATE_ROOT
else
  TEMPLATE_ROOT=$REPO_TEMPLATE_ROOT
fi

usage() {
  cat <<EOF2
Usage: $PROGRAM_NAME <base> [destination]

Install a devcontainer base template into destination.

Arguments:
  base         Template name such as: $(list_bases_inline)
  destination  Target directory to copy into (default: ./)

Options:
  --help       Show this help
  --list-bases Print available base names
EOF2
}

is_template_dir() {
  [ -d "$1" ] && [ -f "$1/.devcontainer/devcontainer.json" ]
}

list_bases() {
  for path in "$TEMPLATE_ROOT"/*; do
    [ -d "$path" ] || continue
    name=$(basename "$path")
    case "$name" in
      .*|bin|completions) continue ;;
    esac
    if is_template_dir "$path"; then
      printf '%s\n' "$name"
    fi
  done | sort
}

list_bases_inline() {
  bases=$(list_bases | tr '\n' ' ' | sed 's/[[:space:]]*$//')
  if [ -n "$bases" ]; then
    printf '%s' "$bases"
  else
    printf '%s' "(none)"
  fi
}

error() {
  printf '%s\n' "$*" >&2
  exit 1
}

record_conflict() {
  rel_path=$1
  reason=$2
  printf '%s: %s\n' "$rel_path" "$reason" >>"$CONFLICTS_FILE"
}

skip_subtree() {
  rel_path=$1
  printf '%s/\n' "$rel_path" >>"$SKIPPED_PATHS_FILE"
}

is_skipped_path() {
  rel_path=$1

  while IFS= read -r skipped_path; do
    [ -n "$skipped_path" ] || continue
    case "$rel_path/" in
      "$skipped_path"*) return 0 ;;
    esac
  done <"$SKIPPED_PATHS_FILE"

  return 1
}

is_binary_file() {
  file_path=$1
  [ -f "$file_path" ] || return 1
  od -An -tx1 -N 4096 "$file_path" | grep -Eq '(^|[[:space:]])00($|[[:space:]])'
}

append_file_content() {
  file_path=$1

  [ -f "$file_path" ] || return 0

  cat "$file_path"

  if [ -s "$file_path" ] && [ "$(tail -c 1 "$file_path" | od -An -tx1 | tr -d ' \n')" != "0a" ]; then
    printf '\n'
  fi
}

write_conflict_file() {
  dest_path=$1
  src_path=$2

  tmp_path=$(mktemp)
  {
    printf '%s\n' '<<<<<<< local'
    append_file_content "$dest_path"
    printf '%s\n' '======='
    append_file_content "$src_path"
    printf '%s\n' '>>>>>>> template'
  } >"$tmp_path"
  mv "$tmp_path" "$dest_path"
}

install_template() {
  src_dir=$1
  dest_dir=$2

  find -H "$src_dir" -mindepth 1 | sort | while IFS= read -r src_path; do
    rel_path=${src_path#"$src_dir"/}
    dest_path=$dest_dir/$rel_path

    if is_skipped_path "$rel_path"; then
      continue
    fi

    if [ -d "$src_path" ]; then
      if [ -e "$dest_path" ] && [ ! -d "$dest_path" ]; then
        record_conflict "$rel_path" "existing path is not a directory"
        skip_subtree "$rel_path"
        continue
      fi

      mkdir -p "$dest_path"
      continue
    fi

    parent_dir=$(dirname "$dest_path")
    if [ -e "$parent_dir" ] && [ ! -d "$parent_dir" ]; then
      record_conflict "$rel_path" "parent path is not a directory"
      continue
    fi
    mkdir -p "$parent_dir"

    if [ ! -e "$dest_path" ]; then
      cp "$src_path" "$dest_path"
      continue
    fi

    if [ -d "$dest_path" ]; then
      record_conflict "$rel_path" "existing path is a directory"
      continue
    fi

    if [ ! -f "$dest_path" ]; then
      record_conflict "$rel_path" "existing path type is unsupported"
      continue
    fi

    if cmp -s "$src_path" "$dest_path"; then
      continue
    fi

    if is_binary_file "$src_path" || is_binary_file "$dest_path"; then
      record_conflict "$rel_path" "binary file differs; resolve manually"
      continue
    fi

    write_conflict_file "$dest_path" "$src_path"
    record_conflict "$rel_path" "conflict markers written"
  done
}

if [ "${1-}" = "--help" ]; then
  usage
  exit 0
fi

if [ "${1-}" = "--list-bases" ]; then
  list_bases
  exit 0
fi

[ $# -ge 1 ] || {
  usage >&2
  exit 1
}

[ $# -le 2 ] || error "Too many arguments. Run '$PROGRAM_NAME --help' for usage."

base_name=$1
destination=${2:-./}

case "$base_name" in
  .*|"") error "Invalid base name: $base_name" ;;
esac

src_dir=$TEMPLATE_ROOT/$base_name
is_template_dir "$src_dir" || error "Unknown base '$base_name'. Available bases: $(list_bases_inline)"

[ -e "$destination" ] || error "Destination does not exist: $destination"
[ -d "$destination" ] || error "Destination is not a directory: $destination"

dest_dir=$(CDPATH= cd -- "$destination" && pwd)
CONFLICTS_FILE=$(mktemp)
SKIPPED_PATHS_FILE=$(mktemp)
trap 'rm -f "$CONFLICTS_FILE" "$SKIPPED_PATHS_FILE"' EXIT

install_template "$src_dir" "$dest_dir"

printf "Installed '%s' into %s\n" "$base_name" "$dest_dir"

if [ -s "$CONFLICTS_FILE" ]; then
  printf '%s\n' 'Conflicts require manual resolution in the following files:' >&2
  sed 's/^/- /' "$CONFLICTS_FILE" >&2
fi
